{
  "name": "fitos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "commit": "cz"
  },
  "devDependencies": {
    "turbo": "latest",
    "@biomejs/biome": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "commitizen": "latest",
    "cz-conventional-changelog": "latest"
  }
}